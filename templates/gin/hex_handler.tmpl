package http

import (
	stdhttp "net/http"

	"github.com/gin-gonic/gin"

	"{{.ModulePath}}/modules/{{.ModuleName}}"
)

type {{.ModuleCamel}}Handler struct {
	service {{.ModuleName}}.Service
}

func New(s {{.ModuleName}}.Service) *{{.ModuleCamel}}Handler {
	return &{{.ModuleCamel}}Handler{service: s}
}

func (h *{{.ModuleCamel}}Handler) Get{{.ModuleCamel}}(c *gin.Context) {
	ctx := c.Request.Context()
	id := c.Query("id")
	if id == "" {
		id = "default"
	}
