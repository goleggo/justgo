PORT=8080
ENV=development
{{if .UseDB}}
{{if eq .DBEngine "postgres"}}
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mydb?sslmode=disable
{{else if eq .DBEngine "mysql"}}
DATABASE_URL=root:root@tcp(localhost:3306)/mydb?parseTime=true
{{else if eq .DBEngine "sqlite"}}
DATABASE_URL=mydb.db
{{end}}
{{end}}
{{if .UseObs}}
LOG_LEVEL=info
LOG_FORMAT=text
OTEL_EXPORTER_TYPE=stdout
OTEL_ENDPOINT=localhost:4317
{{end}}
